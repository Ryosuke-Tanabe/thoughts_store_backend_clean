# Google Drive 連携設定
GOOGLE_DRIVE_ROOT_ID=your_drive_root_folder_id_here
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/your/service_account.json

# ジャーナル保存先
JOURNAL_BASE=/path/to/journal_by_day

# ログ・インデックス
LOGS_DIR=/path/to/logs
LOG_INDEX_PATH=/path/to/logs/log_index.md
MEMORY_MAP_MD=/path/to/logs/memory_map.md

# テンプレート
TEMPLATES_DIR=/path/to/templates

# タイムゾーン（デフォルト: Asia/Tokyo）
# SAVE_TZ=Asia/Tokyo

# スレッド・思考のデフォルト所有者名
THREAD_OWNER=your-name
THOUGHT_AUTHOR=your-name
