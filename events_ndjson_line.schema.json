{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skilldays:ssot/events_ndjson_line.schema.json",
  "title": "SkillDays SSOT events.ndjson (one line) schema",
  "description": "NDJSON: 1 line = 1 event envelope. Strict on envelope, flexible on record payload.",
  "type": "object",
  "required": ["v", "record"],
  "additionalProperties": false,
  "properties": {
    "v": {
      "type": "integer",
      "const": 1,
      "description": "Envelope version"
    },
    "record": {
      "type": "object",
      "required": ["schema_version", "type", "author", "tags"],
      "additionalProperties": true,
      "properties": {
        "schema_version": {
          "type": "string",
          "description": "Record schema version (e.g., '1.3')"
        },
        "type": {
          "type": "string",
          "enum": ["thread_event", "thought"],
          "description": "Record type"
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Non-empty tags (max 5)"
        },
        "thread": {
          "type": "object",
          "required": ["thread_id", "phase", "status", "date_local", "title"],
          "additionalProperties": true,
          "properties": {
            "thread_id": {
              "type": "string",
              "pattern": "^T\\d{4,}$",
              "description": "Thread ID (4+ digits). Example: T0171"
            },
            "phase": {
              "type": "string",
              "enum": ["start", "update", "end"]
            },
            "status": {
              "type": "string",
              "minLength": 1
            },
            "date_local": {
              "type": "string",
              "format": "date",
              "description": "Local date (YYYY-MM-DD) validated as a real date"
            },
            "title": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "json": {
          "description": "Structured payload for the record. Intentionally flexible.",
          "type": ["object", "array", "string", "number", "boolean", "null"]
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable one-liner"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "thread_event" } },
            "required": ["type"]
          },
          "then": { "required": ["thread"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "thought" } },
            "required": ["type"]
          },
          "then": {
            "required": ["text"],
            "not": { "required": ["thread"] }
          }
        }
      ]
    }
  }
}
